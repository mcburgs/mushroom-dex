{
  "expo": {
    "name": "FungiDex",
    "slug": "fungidex",
    "scheme": "mushroomdex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.patrick.fungidex",
      "infoPlist": {
        "NSCameraUsageDescription": "FungiDex uses your camera so you can photograph mushrooms and mystery finds.",
        "NSPhotoLibraryUsageDescription": "FungiDex uses your photo library so you can attach mushroom photos to finds and your profile.",
        "NSLocationWhenInUseUsageDescription": "FungiDex uses your location to improve trail forecasts and save find coordinates."
      }
    },
    "android": {
      "package": "com.patrick.fungidex",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bba6ede4-ebda-42f2-90b2-4a22faa476b5"
      }
    },
    "owner": "mcburgs"
  }
}
