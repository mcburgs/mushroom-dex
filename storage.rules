rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // User find photos: owner can write, owner + friends can read
    match /users/{uid}/finds/{mushroomId}/{filename} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null;
    }

    // User avatar: owner can write, any authenticated user can read
    match /users/{uid}/avatar/{filename} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null;
    }
  }
}
